# DzeNhare Next.js environment template
# Copy this file to .env.local for local development.
# Never commit .env.local or real service-role credentials.

# Public Supabase project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Public Supabase anon key. This is safe to expose client-side, but RLS must still be correct.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Intake submissions table name. Leave as intake_submissions unless you intentionally renamed the table.
SUPABASE_TABLE=intake_submissions

# Server-only Supabase service role key.
# Required for protected admin reads, lead updates, and activity history writes.
# Never expose this in client components, browser code, or public repos.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
